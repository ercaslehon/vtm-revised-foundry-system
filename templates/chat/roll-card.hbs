<div class="vtm-chat-card roll-card">
  <h3>{{label}}</h3>
  {{#if actor}}<p><strong>{{actor.name}}</strong></p>{{/if}}
  {{#if flavor}}<p>{{flavor}}</p>{{/if}}
  {{#if components.length}}
    <p>{{localize "VTM_REVISED.Roll.Components"}}: {{#each components}}<span class="roll-component">{{label}} {{value}}</span>{{#unless @last}} + {{/unless}}{{/each}}</p>
  {{/if}}
  <p>{{localize "VTM_REVISED.Roll.BasePool"}}: {{basePool}}</p>
  {{#if healthPenalty}}
    <p>{{localize "VTM_REVISED.Roll.HealthPenalty"}}: {{healthPenalty}} {{#if healthPenaltyLabel}}({{healthPenaltyLabel}}){{/if}}</p>
  {{/if}}
  <p>{{localize "VTM_REVISED.Roll.Pool"}}: {{pool}}, {{localize "VTM_REVISED.Roll.Difficulty"}}: {{difficulty}}</p>
  <p>{{localize "VTM_REVISED.Roll.Dice"}}: {{#each dice}}<span class="die">{{this}}</span> {{/each}}</p>
  <p>{{localize "VTM_REVISED.Roll.RawSuccesses"}}: {{rawSuccesses}} ({{localize "VTM_REVISED.Roll.Tens"}}: {{tens}} ×2), {{localize "VTM_REVISED.Roll.Ones"}}: {{ones}}</p>
  <p class="result {{#if botch}}botch{{/if}}">{{#if botch}}{{localize "VTM_REVISED.Roll.Botched"}}{{else}}{{localize "VTM_REVISED.Roll.Successes"}}: {{successes}}{{/if}}</p>
</div>
