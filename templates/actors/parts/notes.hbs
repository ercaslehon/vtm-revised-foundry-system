<section class="vtm-panel">
  <h2>{{localize "VTM_REVISED.Section.Profile"}}</h2>
  <div class="grid grid-3">
    <label>{{localize "VTM_REVISED.Profile.Player"}} <input name="system.profile.player" value="{{system.profile.player}}"/></label>
    <label>{{localize "VTM_REVISED.Profile.Chronicle"}} <input name="system.profile.chronicle" value="{{system.profile.chronicle}}"/></label>
    <label>{{localize "VTM_REVISED.Profile.Concept"}} <input name="system.profile.concept" value="{{system.profile.concept}}"/></label>
    <label>{{localize "VTM_REVISED.Profile.Sire"}} <input name="system.profile.sire" value="{{system.profile.sire}}"/></label>
    <label>{{localize "VTM_REVISED.Profile.Sect"}}
      <select name="system.profile.sect">
        <option value="">{{localize "VTM_REVISED.Empty"}}</option>
        {{#each config.sectOptions as |sect|}}
          <option value="{{sect.name}}" {{#if (eq ../system.profile.sect sect.name)}}selected{{/if}}>{{sect.name}}</option>
        {{/each}}
      </select>
    </label>
    <label>{{localize "VTM_REVISED.Profile.Age"}} <input name="system.profile.age" value="{{system.profile.age}}"/></label>
  </div>
</section>
<section class="vtm-panel text-blocks">
  <label>{{localize "VTM_REVISED.Profile.Appearance"}} {{editor system.profile.appearance target="system.profile.appearance" button=true editable=editable}}</label>
  <label>{{localize "VTM_REVISED.Profile.History"}} {{editor system.profile.history target="system.profile.history" button=true editable=editable}}</label>
  <label>{{localize "VTM_REVISED.Profile.Goals"}} {{editor system.profile.goals target="system.profile.goals" button=true editable=editable}}</label>
  <label>{{localize "VTM_REVISED.Profile.AlliesContacts"}} {{editor system.profile.alliesContacts target="system.profile.alliesContacts" button=true editable=editable}}</label>
  <label>{{localize "VTM_REVISED.Profile.Possessions"}} {{editor system.profile.possessions target="system.profile.possessions" button=true editable=editable}}</label>
  <label>{{localize "VTM_REVISED.Profile.Notes"}} {{editor system.profile.notes target="system.profile.notes" button=true editable=editable}}</label>
</section>
