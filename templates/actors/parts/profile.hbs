<section class="vtm-panel vtm-health-scroll-block">
  <article class="vtm-tracker-card vtm-tracker-health">
    <h3><i class="fas fa-heart-crack"></i> {{localize "VTM_REVISED.Section.Health"}}</h3>
    <p class="health-active-penalty">
      {{#if activeHealthPenalty.incapacitated}}
        {{activeHealthPenalty.label}}: {{localize "VTM_REVISED.HealthPenalty.out"}}
      {{else}}
        {{activeHealthPenalty.label}}: {{activeHealthPenalty.value}} {{localize "VTM_REVISED.Roll.DiceShort"}}
      {{/if}}
    </p>
    <div class="health-grid health-check-grid">
      {{#each healthRows as |row|}}
        <label class="health-row {{#if row.checked}}is-checked{{/if}}">
          <input type="checkbox" class="health-checkbox" data-health="{{row.key}}" {{checked row.checked}}/>
          <span class="health-info">
            <span class="health-name">{{row.label}}</span>
            <span class="health-penalty">{{row.penaltyLabel}}</span>
          </span>
        </label>
      {{/each}}
    </div>
  </article>
</section>
