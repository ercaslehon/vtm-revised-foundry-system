<div class="{{cssClass}} vtm-sheet vtm-sheet-v2 vtm-vampire-layout vtm-vampire-shell">
  <section class="vtm-top-shell">
    <aside class="portrait-card vtm-portrait-card">
      <div class="vtm-portrait-frame">
        <img class="profile-img actor-portrait-edit" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
      </div>
      <div class="portrait-actions vtm-portrait-actions">
        <button type="button" class="actor-portrait-edit" title="{{localize 'VTM_REVISED.Portrait.Edit'}}"><i class="fas fa-image"></i></button>
        <button type="button" class="actor-portrait-sync-token" title="{{localize 'VTM_REVISED.Portrait.SyncToken'}}"><i class="fas fa-user-tag"></i></button>
        <button type="button" class="actor-portrait-reset" title="{{localize 'VTM_REVISED.Portrait.Reset'}}"><i class="fas fa-rotate-left"></i></button>
      </div>
      <input type="hidden" name="img" value="{{actor.img}}"/>
      <input type="hidden" name="system.profile.avatar" value="{{system.profile.avatar}}"/>
    </aside>

    <div class="vtm-top-stack">
      <header class="sheet-header vtm-identity-panel">
        <h1 class="vtm-character-name">
          <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'VTM_REVISED.Actor.Name'}}"/>
        </h1>

        <div class="vtm-identity-grid">
          <label class="vtm-identity-cell clan-picker-label">
            <span>{{localize "VTM_REVISED.Profile.Clan"}}</span>
            <div class="clan-picker-row vtm-control-with-book">
              <select name="system.profile.clan" class="clan-select">
                <option value="">{{localize "VTM_REVISED.Empty"}}</option>
                {{#if selectedClan}}
                  {{#unless selectedClan.slug}}
                    <option value="{{system.profile.clan}}" selected>{{system.profile.clan}} · {{localize "VTM_REVISED.Archetype.Custom"}}</option>
                  {{/unless}}
                {{/if}}
                {{#each config.clanOptions as |clan|}}
                  <option value="{{clan.name}}" {{#if (eq ../system.profile.clan clan.name)}}selected{{/if}}>{{clan.name}}</option>
                {{/each}}
              </select>
              <button type="button" class="clan-card-open vtm-book-button" title="{{localize 'VTM_REVISED.Clan.OpenCard'}}"><i class="fas fa-book-open"></i></button>
            </div>
          </label>

          <label class="vtm-identity-cell">
            <span>{{localize "VTM_REVISED.Profile.Generation"}}</span>
            <select name="system.profile.generation" class="generation-select">
              {{#each generationOptions as |option|}}
                <option value="{{option.key}}" {{#if (eq ../generationCaps.key option.key)}}selected{{/if}}>{{option.label}}</option>
              {{/each}}
            </select>
          </label>

          <label class="vtm-identity-cell">
            <span>{{localize "VTM_REVISED.Profile.Nature"}}</span>
            <div class="archetype-picker-row vtm-control-with-book">
              <select name="system.profile.nature" class="archetype-select">
                <option value="">{{localize "VTM_REVISED.Empty"}}</option>
                {{#if selectedNature.isCustom}}
                  <option value="{{system.profile.nature}}" selected>{{system.profile.nature}} · {{localize "VTM_REVISED.Archetype.Custom"}}</option>
                {{/if}}
                {{#each archetypeOptions as |archetype|}}
                  <option value="{{archetype.name}}" {{#if (eq ../system.profile.nature archetype.name)}}selected{{/if}}>{{archetype.name}}</option>
                {{/each}}
              </select>
              <button type="button" class="archetype-card-open vtm-book-button" data-kind="nature" title="Открыть описание Натуры"><i class="fas fa-book-open"></i></button>
            </div>
          </label>

          <label class="vtm-identity-cell">
            <span>{{localize "VTM_REVISED.Profile.Demeanor"}}</span>
            <div class="archetype-picker-row vtm-control-with-book">
              <select name="system.profile.demeanor" class="archetype-select">
                <option value="">{{localize "VTM_REVISED.Empty"}}</option>
                {{#if selectedDemeanor.isCustom}}
                  <option value="{{system.profile.demeanor}}" selected>{{system.profile.demeanor}} · {{localize "VTM_REVISED.Archetype.Custom"}}</option>
                {{/if}}
                {{#each archetypeOptions as |archetype|}}
                  <option value="{{archetype.name}}" {{#if (eq ../system.profile.demeanor archetype.name)}}selected{{/if}}>{{archetype.name}}</option>
                {{/each}}
              </select>
              <button type="button" class="archetype-card-open vtm-book-button" data-kind="demeanor" title="Открыть описание Маски"><i class="fas fa-book-open"></i></button>
            </div>
          </label>
        </div>

        <div class="vtm-lore-grid">
          <label class="vtm-lore-cell"><span>{{localize "VTM_REVISED.Profile.Concept"}}</span><input name="system.profile.concept" value="{{system.profile.concept}}"/></label>
          <label class="vtm-lore-cell"><span>{{localize "VTM_REVISED.Profile.Sect"}}</span>
            <select name="system.profile.sect">
              <option value="">{{localize "VTM_REVISED.Empty"}}</option>
              {{#each config.sectOptions as |sect|}}
                <option value="{{sect.name}}" {{#if (eq ../system.profile.sect sect.name)}}selected{{/if}}>{{sect.name}}</option>
              {{/each}}
            </select>
          </label>
          <label class="vtm-lore-cell"><span>{{localize "VTM_REVISED.Profile.Sire"}}</span><input name="system.profile.sire" value="{{system.profile.sire}}"/></label>
          <label class="vtm-lore-cell"><span>{{localize "VTM_REVISED.Profile.Chronicle"}}</span><input name="system.profile.chronicle" value="{{system.profile.chronicle}}"/></label>
        </div>
      </header>

      <section class="vtm-header-resources">
        <section class="vtm-generation-strip">
  <div class="vtm-generation-title">
    <strong>{{localize "VTM_REVISED.Generation.Title"}}</strong>
    <span>{{localize "VTM_REVISED.Profile.Generation"}} {{generationCaps.label}}</span>
  </div>
  <div class="generation-cap-values">
    <span>{{localize "VTM_REVISED.Generation.TraitMax"}}: <strong>{{generationCaps.traitMax}}</strong></span>
    <span>{{localize "VTM_REVISED.Generation.BloodMax"}}: <strong>{{#if generationCaps.bloodMax}}{{generationCaps.bloodMax}}{{else}}?{{/if}}</strong></span>
    <span>{{localize "VTM_REVISED.Generation.BloodPerTurn"}}: <strong>{{#if generationCaps.bloodPerTurn}}{{generationCaps.bloodPerTurn}}{{else}}?{{/if}}</strong></span>
  </div>
  <button type="button" class="generation-sync"><i class="fas fa-rotate"></i> {{localize "VTM_REVISED.Generation.Sync"}}</button>
</section>

        <section class="vtm-top-trackers vtm-header-trackers">
          <article class="vtm-tracker-card vtm-tracker-blood">
    <h3><i class="fas fa-droplet"></i> {{localize "VTM_REVISED.Resource.Blood"}}</h3>
    <div class="resource-controls vtm-tracker-controls">
      <button type="button" class="resource-change" data-resource="resources.blood" data-delta="-1">−</button>
      <input type="number" name="system.resources.blood.value" value="{{system.resources.blood.value}}"/>
      <span>/</span>
      <input type="number" name="system.resources.blood.max" value="{{system.resources.blood.max}}" readonly/>
      <button type="button" class="resource-change" data-resource="resources.blood" data-delta="1">+</button>
    </div>
    <label class="vtm-mini-field">{{localize "VTM_REVISED.Resource.BloodPerTurn"}}
      <input type="number" name="system.resources.bloodPerTurn" value="{{system.resources.bloodPerTurn}}" readonly/>
    </label>
  </article><article class="vtm-tracker-card vtm-tracker-willpower">
    <h3><i class="fas fa-eye"></i> {{localize "VTM_REVISED.Resource.Willpower"}}</h3>
    <div class="resource-controls vtm-tracker-controls">
      <button type="button" class="resource-change" data-resource="resources.willpower" data-delta="-1">−</button>
      <input type="number" name="system.resources.willpower.value" value="{{system.resources.willpower.value}}"/>
      <span>/</span>
      <input type="number" name="system.resources.willpower.max" value="{{system.resources.willpower.max}}"/>
      <button type="button" class="resource-change" data-resource="resources.willpower" data-delta="1">+</button>
    </div>
  </article><article class="vtm-tracker-card vtm-tracker-humanity">
    <h3><i class="fas fa-ankh"></i> {{localize "VTM_REVISED.Resource.Humanity"}}</h3>
    <div class="resource-controls vtm-tracker-controls">
      <button type="button" class="resource-change" data-resource="resources.humanity" data-delta="-1">−</button>
      <input type="number" name="system.resources.humanity.value" value="{{system.resources.humanity.value}}"/>
      <span>/</span>
      <input type="number" name="system.resources.humanity.max" value="{{system.resources.humanity.max}}"/>
      <button type="button" class="resource-change" data-resource="resources.humanity" data-delta="1">+</button>
    </div>
    <label class="vtm-mini-field vtm-path-mini">{{localize "VTM_REVISED.Resource.Path"}}
      <div class="morality-picker-row vtm-control-with-book">
        <select name="system.resources.pathName" class="morality-path-select">
          {{#each moralityOptions as |path|}}
            <option value="{{path.name}}" {{#if (eq ../system.resources.pathName path.name)}}selected{{/if}}>{{path.label}}</option>
          {{/each}}
        </select>
        <button type="button" class="morality-path-card-open vtm-book-button" title="Открыть описание Пути/Дороги"><i class="fas fa-book-open"></i></button>
      </div>
    </label>
  </article><article class="vtm-tracker-card vtm-tracker-xp">
    <h3><i class="fas fa-circle-nodes"></i> {{localize "VTM_REVISED.Resource.Experience"}}</h3>
    <div class="vtm-xp-single">
      <label>{{localize "VTM_REVISED.Resource.ExperienceAvailable"}}
        <input type="number" name="system.resources.experience.available" value="{{system.resources.experience.available}}"/>
      </label>
    </div>
  </article>
        </section>
      </section>
    </div>
  </section>

  <section class="vtm-sheet-body vtm-scroll-from-health">
    {{> "systems/vtm-revised/templates/actors/parts/profile.hbs"}}

    <section class="vtm-panel vtm-roll-builder vtm-command-strip">
        <h2>{{localize "VTM_REVISED.Roll.BuilderTitle"}}</h2>
        <div class="vtm-roll-builder-grid">
          <label><span>{{localize "VTM_REVISED.Roll.FirstTrait"}}</span>
            <select data-roll-field="firstTrait">
              {{#each rollTraitOptionGroups as |group|}}
                <optgroup label="{{group.label}}">
                  {{#each group.options as |option|}}
                    <option value="{{option.key}}">{{option.display}}</option>
                  {{/each}}
                </optgroup>
              {{/each}}
            </select>
          </label>
          <label><span>{{localize "VTM_REVISED.Roll.SecondTrait"}}</span>
            <select data-roll-field="secondTrait">
              <option value="">{{localize "VTM_REVISED.Roll.NoSecondTrait"}}</option>
              {{#each rollTraitOptionGroups as |group|}}
                <optgroup label="{{group.label}}">
                  {{#each group.options as |option|}}
                    <option value="{{option.key}}">{{option.display}}</option>
                  {{/each}}
                </optgroup>
              {{/each}}
            </select>
          </label>
          <label><span>{{localize "VTM_REVISED.Roll.Difficulty"}}</span>
            <input type="number" data-roll-field="difficulty" min="2" max="10" value="6"/>
          </label>
          <label><span>{{localize "VTM_REVISED.Roll.Label"}}</span>
            <input type="text" data-roll-field="label" placeholder="{{localize 'VTM_REVISED.Roll.LabelPlaceholder'}}"/>
          </label>
          <button type="button" class="vtm-roll-builder-submit"><i class="fas fa-dice-d10"></i> {{localize "VTM_REVISED.Roll.RollButton"}}</button>
        </div>
      </section>

    <nav class="vtm-section-tabs vtm-fixed-tabs" aria-label="Разделы листа">
      <button type="button" class="vtm-tab-item {{#if (eq activeSheetTab "main")}}is-active{{/if}}" data-vtm-tab="main"><i class="fas fa-dungeon"></i> Основное</button>
      <button type="button" class="vtm-tab-item {{#if (eq activeSheetTab "powers")}}is-active{{/if}}" data-vtm-tab="powers"><i class="fas fa-wand-sparkles"></i> Силы</button>
      <button type="button" class="vtm-tab-item {{#if (eq activeSheetTab "profile")}}is-active{{/if}}" data-vtm-tab="profile"><i class="fas fa-user"></i> Профиль</button>
    </nav>

    <div class="vtm-tab-panels">
      <section class="vtm-tab-panel {{#if (eq activeSheetTab "main")}}is-active{{/if}}" data-vtm-tab-panel="main">
        <div class="vtm-main-grid vtm-main-grid-single">
          <main class="vtm-main-left">
            {{> "systems/vtm-revised/templates/actors/parts/attributes.hbs"}}
            {{> "systems/vtm-revised/templates/actors/parts/abilities.hbs"}}

            <details class="vtm-panel vtm-optional-weapons">
              <summary><i class="fas fa-khanda"></i> {{localize "VTM_REVISED.Weapon.Section"}}</summary>
              {{> "systems/vtm-revised/templates/actors/parts/weapons.hbs"}}
            </details>
          </main>
        </div>
      </section>

      <section class="vtm-tab-panel {{#if (eq activeSheetTab "powers")}}is-active{{/if}}" data-vtm-tab-panel="powers">
        <div class="vtm-powers-grid">
          <section class="vtm-panel item-section vtm-disciplines-panel">
            <h2>{{localize "TYPES.Item.discipline"}}</h2>
            <p class="muted">Дисциплины персонажа. Книжечки открывают справочные карточки с уровнями, описанием и автоматизацией.</p>
            <div class="vtm-discipline-list-only">
              <div class="vtm-inline-heading-actions">
                <h3>{{localize "TYPES.Item.discipline"}}</h3>
                <button type="button" class="item-create vtm-small-add-button" data-type="discipline" title="{{localize "DOCUMENT.Create" type=(localize "TYPES.Item.discipline")}}" aria-label="{{localize "DOCUMENT.Create" type=(localize "TYPES.Item.discipline")}}">
                  <i class="fas fa-plus"></i>
                </button>
              </div>
              {{> "systems/vtm-revised/templates/actors/parts/item-list.hbs" items=disciplines ratingField="rating" ratingMax=generationCaps.traitMax}}
            </div>
          </section>

          {{> "systems/vtm-revised/templates/actors/parts/blood-magic.hbs"}}
        </div>
      </section>

      <section class="vtm-tab-panel {{#if (eq activeSheetTab "profile")}}is-active{{/if}}" data-vtm-tab-panel="profile">
        <div class="vtm-profile-grid">
          <section class="vtm-panel item-section vtm-social-assets-panel">
            <h2>Преимущества</h2>
            <div class="advantage-grid vtm-profile-advantage-grid">
              <div>
                <h3>{{localize "TYPES.Item.background"}} <button type="button" class="background-add-from-catalog" data-type="background" title="{{localize "VTM_REVISED.Background.AddFromCatalog"}}">+</button></h3>
                {{> "systems/vtm-revised/templates/actors/parts/item-list.hbs" items=backgrounds ratingField="rating" ratingMax=generationCaps.traitMax}}
              </div>
              <div>
                <h3>{{localize "TYPES.Item.merit"}} <button type="button" class="merit-add-from-catalog" data-type="merit" title="{{localize "VTM_REVISED.MeritFlaw.AddFromCatalog"}}">+</button></h3>
                {{> "systems/vtm-revised/templates/actors/parts/item-list.hbs" items=merits ratingField="points"}}
              </div>
              <div>
                <h3>{{localize "TYPES.Item.flaw"}} <button type="button" class="flaw-add-from-catalog" data-type="flaw" title="{{localize "VTM_REVISED.MeritFlaw.AddFromCatalog"}}">+</button></h3>
                {{> "systems/vtm-revised/templates/actors/parts/item-list.hbs" items=flaws ratingField="points"}}
              </div>
              <div>
                <h3>{{localize "TYPES.Item.equipment"}} <button type="button" class="item-create" data-type="equipment">+</button></h3>
                {{> "systems/vtm-revised/templates/actors/parts/item-list.hbs" items=equipment ratingField="quantity"}}
              </div>
            </div>
          </section>

          <section class="vtm-panel archetypes-panel">
            <h2>{{localize "VTM_REVISED.Archetype.Title"}}</h2>
            <p class="archetype-help">{{localize "VTM_REVISED.Archetype.Help"}}</p>
            <div class="archetype-grid">
              <article class="archetype-card nature-card">
                <header>
                  <h3>{{localize "VTM_REVISED.Archetype.Nature"}}: {{#if selectedNature}}{{selectedNature.name}}{{else}}{{localize "VTM_REVISED.Empty"}}{{/if}}</h3>
                  {{#if selectedNature}}<span>{{selectedNature.motto}}</span>{{/if}}
                </header>
                {{#if selectedNature}}
                  <p>{{selectedNature.summary}}</p>
                  <div class="archetype-mechanic">
                    <strong>{{localize "VTM_REVISED.Archetype.WillpowerRegain"}}:</strong> {{selectedNature.regain}}
                  </div>
                  <button type="button" class="nature-willpower-restore"><i class="fas fa-plus"></i> {{localize "VTM_REVISED.Archetype.RestoreWillpower"}}</button>
                {{else}}
                  <p>{{localize "VTM_REVISED.Archetype.SelectNaturePrompt"}}</p>
                {{/if}}
              </article>
              <article class="archetype-card demeanor-card">
                <header>
                  <h3>{{localize "VTM_REVISED.Archetype.Demeanor"}}: {{#if selectedDemeanor}}{{selectedDemeanor.name}}{{else}}{{localize "VTM_REVISED.Empty"}}{{/if}}</h3>
                  {{#if selectedDemeanor}}<span>{{selectedDemeanor.motto}}</span>{{/if}}
                </header>
                {{#if selectedDemeanor}}
                  <p>{{selectedDemeanor.summary}}</p>
                  <div class="archetype-mechanic">
                    <strong>{{localize "VTM_REVISED.Archetype.DemeanorMechanicTitle"}}:</strong> {{localize "VTM_REVISED.Archetype.DemeanorMechanic"}}
                  </div>
                {{else}}
                  <p>{{localize "VTM_REVISED.Archetype.SelectDemeanorPrompt"}}</p>
                {{/if}}
              </article>
            </div>
          </section>

          {{> "systems/vtm-revised/templates/actors/parts/notes-v2.hbs"}}

        </div>
      </section>
    </div>
  </section>
</div>
